{
	"compatibility_date": "2026-05-31",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "mshportfolio",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
