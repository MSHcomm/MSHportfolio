---
import Layout from '../layouts/Layout.astro';
import InteractiveBackground from '../components/InteractiveBackground';
import InteractiveTerminal from '../components/InteractiveTerminal';
import BentoStack from '../components/BentoStack';
import InteractiveTimeline from '../components/InteractiveTimeline';
import ProjectShowcase from '../components/ProjectShowcase';
---

<Layout>
  <!-- Interactive Circuit Background behind everything -->
  <div style="position: relative; overflow: hidden; min-height: 100vh;">
    <InteractiveBackground client:load />

    <!-- 1. SUMMARY / HERO SECTION -->
    <header id="hero" class="container" style="min-height: 100vh; display: flex; align-items: center; justify-content: space-between; position: relative; padding-top: 120px; padding-bottom: 60px;">
      <div style="width: 100%; display: grid; grid-template-columns: repeat(12, 1fr); gap: var(--gutter-desktop); align-items: center;">
        
        <!-- Summary & Actions -->
        <div class="reveal" style="grid-column: span 9; position: relative; z-index: 10; display: flex; flex-direction: column; align-items: flex-start; text-align: left;">
          <div 
            style={{
              display: 'inline-block',
              background: 'rgba(88, 166, 255, 0.1)',
              border: '1px solid rgba(88, 166, 255, 0.3)',
              color: 'var(--primary)',
              fontFamily: 'var(--font-mono)',
              fontSize: '10px',
              fontWeight: '700',
              padding: '6px 14px',
              borderRadius: '4px',
              marginBottom: '20px',
              textTransform: 'uppercase',
              letterSpacing: '0.1em',
              alignSelf: 'flex-start'
            }}
          >
            INITIALIZING_CORE // v7.0
          </div>

          <h1 class="title-xl" style="color: var(--text-primary); margin-bottom: 20px; text-align: left; font-size: clamp(2.8rem, 5vw, 4.5rem);">
            Mohamed Gedan
            <span style="display: flex; flex-direction: column; gap: 4px; color: var(--primary); font-size: clamp(1.2rem, 2.5vw, 2rem); font-family: var(--font-mono); font-weight: 500; margin-top: 12px; text-align: left; line-height: 1.5;">
              <span>Senior Embedded Software Engineer <span style="color: var(--text-muted);">\</span></span>
              <span>Firmware &amp; Embedded Linux <span style="color: var(--text-muted);">\</span></span>
              <span>SCADA &amp; EMS Engineer</span>
            </span>
          </h1>

          <h2 style="font-family: var(--font-mono); font-size: 13px; color: var(--secondary); margin-bottom: 12px; letter-spacing: 0.1em;">
            // CORE_PROFILE
          </h2>
          
          <p class="body-md" style="margin-bottom: 36px; text-align: justify; line-height: 1.6; color: var(--text-secondary);">
            Senior Embedded Software Engineer with 7+ years of experience in low-level embedded systems and microcontroller-based development. Strong background in Embedded C/C++, Embedded Linux, peripheral drivers, real-time systems, and hardware-near debugging. Experienced across the full software development lifecycle, including design, implementation, verification, and system integration. Proven delivery of mission-critical software in globally distributed teams, with hands-on CI/CD automation.
          </p>

          <!-- Quick Action Buttons -->
          <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 24px; justify-content: flex-start;">
            <a href="/files/Mohamed Gedan - CV.pdf" download class="btn btn-primary text-mono">
              <span class="material-symbols-outlined" style="font-size: 18px;">download</span>
              Download CV (PDF) - English Version
            </a>
            <a href="/files/Mohamed Gedan - Lebenslauf.pdf" download class="btn btn-secondary text-mono">
              <span class="material-symbols-outlined" style="font-size: 18px;">download</span>
              Download CV (PDF) - German Version
            </a>
            <a href="/files/Empfehlungsschreiben_Mohamed_Gedan_SE.pdf" download class="btn btn-secondary text-mono">
              <span class="material-symbols-outlined" style="font-size: 18px;">article</span>
              Download Recommendation letter (PDF)
            </a>
            <a href="#contact" class="btn btn-text text-mono" style="margin-left: 8px;">
              Get in Touch ➜
            </a>
          </div>
        </div>

        <!-- Terminal Console Emulator -->
        <div class="reveal" style="grid-column: span 3; position: relative; z-index: 10;">
          <InteractiveTerminal client:load />
        </div>
      </div>
    </header>

    <!-- 2. WORK EXPERIENCE -->
    <section id="experience" class="container" style="padding-top: 100px; padding-bottom: 60px; position: relative;">
      <div class="section-divider reveal">
        <h2>01. WORK_EXPERIENCE</h2>
        <div class="line"></div>
      </div>
      <div style="margin-bottom: 80px;">
        <InteractiveTimeline client:load />
      </div>

      <!-- Nested Selected Systems Architecture Specs Drawer -->
      <div class="reveal" style="border-top: 1px dashed var(--card-border); padding-top: 60px; margin-top: 20px;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 36px;">
          <span class="material-symbols-outlined" style="color: var(--primary); font-size: 20px;">schema</span>
          <h3 style="font-family: var(--font-mono); font-size: 14px; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.1em;">
            // DEPLOYED_ARTIFACTS // SYSTEM_ARCHITECTURE_SPECS
          </h3>
        </div>
        <ProjectShowcase client:load />
      </div>
    </section>

    <!-- 3. SKILLS & TOOLS (Bento Stack with 13 vertical columns) -->
    <section id="skills" class="container" style="padding-top: 100px; padding-bottom: 100px; position: relative;">
      <div class="section-divider reveal">
        <h2>02. SKILLS_&amp;_TOOLS</h2>
        <div class="line"></div>
      </div>
      <div class="reveal">
        <BentoStack client:load />
      </div>
    </section>

    <!-- 4. CERTIFICATIONS -->
    <section id="certifications" class="container" style="padding-top: 100px; padding-bottom: 100px; position: relative;">
      <div class="section-divider reveal">
        <h2>03. CERTIFICATIONS</h2>
        <div class="line"></div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;" class="reveal">
        <!-- Cert 1 -->
        <div class="bento-cell" style="padding: 24px; background: var(--card-bg);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <span class="material-symbols-outlined" style="color: var(--primary); font-size: 32px;">verified_user</span>
            <span style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); padding: 2px 8px; border-radius: 4px;">
              01/2026
            </span>
          </div>
          <h3 style="font-family: var(--font-mono); font-size: 15px; color: var(--text-primary); margin-bottom: 8px;">
            Certified SAFe 6 Practitioner
          </h3>
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);">
            Certificate ID: 59568971-4201
          </div>
        </div>

        <!-- Cert 2 -->
        <div class="bento-cell" style="padding: 24px; background: var(--card-bg);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <span class="material-symbols-outlined" style="color: var(--primary); font-size: 32px;">lan</span>
            <span style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); padding: 2px 8px; border-radius: 4px;">
              02/2024
            </span>
          </div>
          <h3 style="font-family: var(--font-mono); font-size: 15px; color: var(--text-primary); margin-bottom: 8px;">
            Certified PROFINET Engineer
          </h3>
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); line-height: 1.4;">
            PI training center at ČVUT Prague (industrial-automation-group)
          </div>
        </div>

        <!-- Cert 3 -->
        <div class="bento-cell" style="padding: 24px; background: var(--card-bg);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <span class="material-symbols-outlined" style="color: var(--primary); font-size: 32px;">bug_report</span>
            <span style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); padding: 2px 8px; border-radius: 4px;">
              03/2018
            </span>
          </div>
          <h3 style="font-family: var(--font-mono); font-size: 15px; color: var(--text-primary); margin-bottom: 8px;">
            Certificate Software Tester (ISTQB – FL)
          </h3>
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);">
            Certificate #180311012
          </div>
        </div>
      </div>
    </section>

    <!-- 5. LANGUAGE -->
    <section id="languages" class="container" style="padding-top: 100px; padding-bottom: 100px; position: relative;">
      <div class="section-divider reveal">
        <h2>04. LANGUAGES</h2>
        <div class="line"></div>
      </div>

      <div class="reveal" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px;">
        <!-- Arabic -->
        <div class="bento-cell" style="padding: 28px; background: var(--card-bg); display: flex; flex-direction: column; gap: 20px;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
              <div style="font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px;">// MOTHER_TONGUE</div>
              <h3 style="font-family: var(--font-mono); font-size: 20px; color: var(--text-primary); font-weight: 700;">Arabic</h3>
            </div>
            <span style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); padding: 2px 8px; border-radius: 4px; border: 1px solid rgba(88, 166, 255, 0.2);">NATIVE</span>
          </div>
          <div>
            <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); margin-bottom: 6px;">
              <span>PROFICIENCY</span><span style="color: var(--primary); font-weight: 700;">100%</span>
            </div>
            <div style="height: 3px; background: var(--card-border); border-radius: 2px; overflow: hidden;">
              <div style="height: 100%; width: 100%; background: var(--primary); border-radius: 2px;"></div>
            </div>
          </div>
        </div>

        <!-- English -->
        <div class="bento-cell" style="padding: 28px; background: var(--card-bg); display: flex; flex-direction: column; gap: 20px;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
              <div style="font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px;">// PROFESSIONAL_COMM</div>
              <h3 style="font-family: var(--font-mono); font-size: 20px; color: var(--text-primary); font-weight: 700;">English</h3>
            </div>
            <span style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); padding: 2px 8px; border-radius: 4px; border: 1px solid rgba(88, 166, 255, 0.2);">C1</span>
          </div>
          <div>
            <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); margin-bottom: 6px;">
              <span>PROFICIENCY</span><span style="color: var(--primary); font-weight: 700;">95%</span>
            </div>
            <div style="height: 3px; background: var(--card-border); border-radius: 2px; overflow: hidden;">
              <div style="height: 100%; width: 95%; background: var(--primary); border-radius: 2px;"></div>
            </div>
          </div>
        </div>

        <!-- German -->
        <div class="bento-cell" style="padding: 28px; background: var(--card-bg); display: flex; flex-direction: column; gap: 20px;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
              <div style="font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px;">// LOCAL_LANG</div>
              <h3 style="font-family: var(--font-mono); font-size: 20px; color: var(--text-primary); font-weight: 700;">German</h3>
            </div>
            <span style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); padding: 2px 8px; border-radius: 4px; border: 1px solid rgba(88, 166, 255, 0.2);">A2</span>
          </div>
          <div>
            <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); margin-bottom: 6px;">
              <span>PROFICIENCY</span><span style="color: var(--primary); font-weight: 700;">45%</span>
            </div>
            <div style="height: 3px; background: var(--card-border); border-radius: 2px; overflow: hidden;">
              <div style="height: 100%; width: 45%; background: var(--primary); border-radius: 2px;"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. EDUCATION -->
    <section id="education" class="container" style="padding-top: 100px; padding-bottom: 100px; position: relative;">
      <div class="section-divider reveal">
        <h2>05. EDUCATION</h2>
        <div class="line"></div>
      </div>

      <div class="reveal" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 24px;">
        <!-- M.Sc. -->
        <div class="bento-cell" style="padding: 28px; background: var(--card-bg); display: flex; flex-direction: column; gap: 16px; position: relative;">
          <div style="position: absolute; top: 20px; right: 20px; font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); border: 1px solid rgba(88, 166, 255, 0.2); padding: 2px 8px; border-radius: 4px;">
            02/2015 – 02/2016
          </div>
          <div style="display: flex; align-items: center; gap: 14px;">
            <span class="material-symbols-outlined" style="color: var(--primary); font-size: 28px;">school</span>
            <div style="font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;">// POSTGRADUATE</div>
          </div>
          <div>
            <h3 style="font-family: var(--font-mono); font-size: 15px; color: var(--text-primary); font-weight: 700; margin-bottom: 6px;">
              M.Sc. Electronics &amp; Communications Engineering
            </h3>
            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--secondary); margin-bottom: 12px;">
              Benha University — Faculty of EE. Engineering
            </div>
            <p style="font-size: 12px; color: var(--text-secondary); line-height: 1.6; font-family: var(--font-sans);">
              <span style="color: var(--primary); font-family: var(--font-mono); font-weight: 700;">RESEARCH:</span> DVB-T Spectrum Sensing for Cognitive Radio over Software Defined Radio (SDR).
            </p>
          </div>
          <div style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.05); color: var(--text-muted); border: 1px dashed var(--card-border); padding: 4px 10px; border-radius: 4px; width: fit-content;">
            STUDIES_DISCONTINUED_AFTER_YEAR_ONE
          </div>
        </div>

        <!-- B.Sc. -->
        <div class="bento-cell" style="padding: 28px; background: var(--card-bg); display: flex; flex-direction: column; gap: 16px; position: relative;">
          <div style="position: absolute; top: 20px; right: 20px; font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); border: 1px solid rgba(88, 166, 255, 0.2); padding: 2px 8px; border-radius: 4px;">
            09/2005 – 07/2010
          </div>
          <div style="display: flex; align-items: center; gap: 14px;">
            <span class="material-symbols-outlined" style="color: var(--primary); font-size: 28px;">history_edu</span>
            <div style="font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;">// UNDERGRADUATE</div>
          </div>
          <div>
            <h3 style="font-family: var(--font-mono); font-size: 15px; color: var(--text-primary); font-weight: 700; margin-bottom: 6px;">
              B.Sc. Electronics &amp; Communications Engineering
            </h3>
            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--secondary); margin-bottom: 12px;">
              MAM — Faculty of EE. Engineering
            </div>
          </div>
          <div style="font-family: var(--font-mono); font-size: 10px; background: rgba(88, 166, 255, 0.1); color: var(--primary); border: 1px solid rgba(88, 166, 255, 0.2); padding: 4px 10px; border-radius: 4px; width: fit-content; font-weight: 700; letter-spacing: 0.05em;">
            HONORS_GRADUATION_DISTINCTION
          </div>
        </div>
      </div>
    </section>

    <!-- 7. REFERENCE -->
    <section id="reference" class="container" style="padding-top: 100px; padding-bottom: 100px; position: relative;">
      <div class="section-divider reveal">
        <h2>06. REFERENCE</h2>
        <div class="line"></div>
      </div>
      
      <div class="reveal bento-cell" style="padding: 40px; background: var(--card-bg); position: relative; border-left: 3px solid var(--primary);">
        <span class="material-symbols-outlined" style="font-size: 64px; color: rgba(88, 166, 255, 0.1); position: absolute; top: 20px; right: 20px; pointer-events: none; user-select: none;">
          format_quote
        </span>
        
        <p style="font-family: var(--font-mono); font-size: 15px; line-height: 1.8; color: var(--text-primary); margin-bottom: 28px; font-style: italic;">
          "I highly recommend Mohamed Gedan as an exceptional Senior Embedded Software Engineer. During our time together, he demonstrated remarkable technical skills and a deep understanding of embedded systems. His expertise in firmware development and his ability to tackle complex challenges with precision and creativity were invaluable to our team..."
        </p>

        <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 20px;">
          <div>
            <div style="font-family: var(--font-mono); font-size: 14px; font-weight: 700; color: var(--primary);">
              Felix Roth
            </div>
            <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);">
              Technical Manager at Schneider Electric Automation GmbH
            </div>
          </div>
          
          <div style="display: flex; align-items: center; gap: 16px;">
            <a href="#" class="btn btn-secondary text-mono" style="font-size: 11px; padding: 8px 16px;">
              Request Recommendation letter (Empfehlungsschreiben)
            </a>
            <span style="font-family: var(--font-mono); font-size: 10px; color: var(--text-muted);">
              // LinkedIn recommendation also available
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT PANEL -->
    <section id="contact" class="container" style="padding-top: 100px; padding-bottom: 120px; position: relative; z-index: 10;">
      <div class="reveal bento-cell" style="padding: 48px; background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg-high) 100%); display: grid; grid-template-columns: repeat(12, 1fr); gap: var(--gutter-desktop); align-items: center;">
        
        <!-- Info text (Spans 7 columns on desktop) -->
        <div style="grid-column: span 7;">
          <h2 style="font-family: var(--font-mono); font-size: clamp(2rem, 4vw, 3rem); color: var(--primary); margin-bottom: 16px;">
            ESTABLISH_CONNECTION //
          </h2>
          <p class="body-lg" style="max-w: 520px; color: var(--text-secondary); margin-bottom: 24px;">
            Open for collaborations on mission-critical embedded systems, firmware architecture consulting, and industrial IoT solutions.
          </p>
          
          <div style="display: flex; flex-direction: column; gap: 12px; font-family: var(--font-mono); font-size: 13px; color: var(--text-secondary);">
            <div style="display: flex; align-items: center; gap: 10px;">
              <span class="material-symbols-outlined" style="color: var(--primary); font-size: 18px;">mail</span>
              <span>mohamed.gedan.88@gmail.com</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
              <span class="material-symbols-outlined" style="color: var(--primary); font-size: 18px;">phone</span>
              <span>+49 151 626 420 77</span>
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
              <span class="material-symbols-outlined" style="color: var(--primary); font-size: 18px;">location_on</span>
              <span>Würzburg, Bayern, Deutschland</span>
            </div>
          </div>
        </div>

        <!-- Call to Action forms/buttons (Spans 5 columns on desktop) -->
        <div style="grid-column: span 5; display: flex; flex-direction: column; gap: 16px; width: 100%;">
          <a href="mailto:mohamed.gedan.88@gmail.com" class="btn btn-primary text-mono" style="padding: 16px; font-size: 13px; width: 100%; display: flex; justify-content: center;">
            <span class="material-symbols-outlined" style="font-size: 18px;">mail</span>
            OPEN_COMMUNICATION_CHANNEL
          </a>

          <a href="tel:+4915162642077" class="btn btn-secondary text-mono" style="padding: 14px; font-size: 12px; width: 100%; display: flex; justify-content: center; gap: 8px;">
            <span class="material-symbols-outlined" style="font-size: 16px;">phone</span>
            +49 151 626 420 77
          </a>

          <div style="display: flex; justify-content: center; gap: 24px; margin-top: 8px;">
            <a href="https://www.linkedin.com/in/mohamed-sayed-eng/" target="_blank" rel="noopener noreferrer" style="color: var(--text-secondary); text-decoration: none; font-family: var(--font-mono); font-size: 12px; display: flex; align-items: center; gap: 6px;" class="nav-item">
              <span class="material-symbols-outlined" style="font-size: 16px;">link</span>
              LinkedIn
            </a>
            <a href="https://github.com/MSHcomm" target="_blank" rel="noopener noreferrer" style="color: var(--text-secondary); text-decoration: none; font-family: var(--font-mono); font-size: 12px; display: flex; align-items: center; gap: 6px;" class="nav-item">
              <span class="material-symbols-outlined" style="font-size: 16px;">terminal</span>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="border-t: 1px solid var(--card-border); background: var(--card-bg-lowest); padding: 48px 0; border-top: 1px solid var(--card-border);">
      <div class="container" style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 24px;">
        <div>
          <span style="font-family: var(--font-mono); font-weight: 700; color: var(--text-primary); font-size: 16px; text-transform: uppercase;">
            MOHAMED GEDAN
          </span>
          <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-top: 4px;">
            © 2026 CORE_SYSTEMS_LOG. ALL RIGHTS RESERVED. HEX_REF: 0x535953
          </div>
        </div>

        <div style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);">
          Built with <strong style="color: var(--primary);">Astro</strong> + <strong style="color: var(--secondary);">React</strong> + Scoped <strong style="color: var(--tertiary);">Vanilla CSS</strong>
