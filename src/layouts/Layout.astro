---
import '../styles/global.css';
import MainScene      from '../components/MainScene';
import SmoothScroll   from '../components/SmoothScroll';
import LanguageToggle from '../components/LanguageToggle';
import ThemeToggle    from '../components/ThemeToggle';
import CookieBanner   from '../components/CookieBanner';
import InteractiveLogo from '../components/InteractiveLogo';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mohamed Gedan | Senior Embedded Systems & Firmware Architect",
  description = "Mohamed Gedan is a Senior Embedded Systems & Firmware Engineer with 7+ years of experience in low-level systems, Embedded Linux, Yocto, real-time RTOS, and communication protocols like EtherCAT and PROFINET."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mohamed Gedan" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Theme FOUC prevention: apply saved theme before first paint -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (savedTheme === 'light' || (!savedTheme && prefersLight)) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <!-- Material Symbols Outlined — self-hosted (GDPR: no third-party CDN) -->
    <link rel="stylesheet" href="/fonts/material-symbols.css" />
  </head>
  <body>
    <!-- Navbar Header -->
    <nav>
      <div class="container nav-container">
        <a href="#hero" class="logo" style="display: flex; align-items: center; gap: 10px;">
          <InteractiveLogo client:load width={32} height={32} />
          MOHAMED GEDAN
        </a>

        <div class="nav-links">
          <a href="#hero"           class="nav-item active"><span data-de="Zusammenfassung">Summary</span></a>
          <a href="#experience"     class="nav-item"><span data-de="Erfahrung">Experience</span></a>
          <a href="#skills"         class="nav-item"><span data-de="Fähigkeiten">Skills</span></a>
          <a href="#certifications" class="nav-item"><span data-de="Zertifikate">Certifications</span></a>
          <a href="#languages"      class="nav-item"><span data-de="Sprachen">Languages</span></a>
          <a href="#education"      class="nav-item"><span data-de="Ausbildung">Education</span></a>
          <a href="#reference"      class="nav-item"><span data-de="Referenzen">References</span></a>
          <ThemeToggle client:load />
          <LanguageToggle client:load />
          <a href="#contact" class="btn btn-secondary" style="padding: 5px 14px; font-size: 0.72rem; height: auto; white-space: nowrap;">
            <span data-de="KONTAKT">GET IN TOUCH</span>
          </a>
        </div>

        <!-- Mobile Nav Trigger Icons -->
        <div class="mobile-icons-container" style="display: none; gap: 12px; color: var(--primary);">
          <span class="material-symbols-outlined" aria-hidden="true">terminal</span>
          <ThemeToggle client:load />
          <LanguageToggle client:load />
          <span class="material-symbols-outlined" aria-hidden="true" id="mobile-menu-toggle" style="cursor: pointer;">menu</span>
        </div>
      </div>

      <!-- Mobile Dropdown -->
      <div id="mobile-menu" style="display: none; flex-direction: column; background: var(--card-bg-lowest); border-bottom: 1px solid var(--card-border); padding: 16px 20px; gap: 8px;">
        <a href="#hero"           class="mobile-nav-item" style="color: var(--text-primary); text-decoration: none; font-family: var(--font-mono); font-size: 1rem; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);"><span data-de="// 01. Zusammenfassung">// 01. Summary</span></a>
        <a href="#experience"     class="mobile-nav-item" style="color: var(--text-primary); text-decoration: none; font-family: var(--font-mono); font-size: 1rem; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);"><span data-de="// 02. Erfahrung">// 02. Experience</span></a>
        <a href="#skills"         class="mobile-nav-item" style="color: var(--text-primary); text-decoration: none; font-family: var(--font-mono); font-size: 1rem; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);"><span data-de="// 03. Fähigkeiten">// 03. Skills</span></a>
        <a href="#certifications" class="mobile-nav-item" style="color: var(--text-primary); text-decoration: none; font-family: var(--font-mono); font-size: 1rem; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);"><span data-de="// 04. Zertifikate">// 04. Certifications</span></a>
        <a href="#languages"      class="mobile-nav-item" style="color: var(--text-primary); text-decoration: none; font-family: var(--font-mono); font-size: 1rem; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);"><span data-de="// 05. Sprachen">// 05. Languages</span></a>
        <a href="#education"      class="mobile-nav-item" style="color: var(--text-primary); text-decoration: none; font-family: var(--font-mono); font-size: 1rem; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);"><span data-de="// 06. Ausbildung">// 06. Education</span></a>
        <a href="#reference"      class="mobile-nav-item" style="color: var(--text-primary); text-decoration: none; font-family: var(--font-mono); font-size: 1rem; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);"><span data-de="// 07. Referenzen">// 07. References</span></a>
        <a href="#contact" class="btn btn-primary" style="width: 100%; text-align: center; margin-top: 8px; padding: 14px;"><span data-de="Kontakt aufnehmen">Get in Touch</span></a>
      </div>
    </nav>

    <!-- GDPR Cookie Consent Banner -->
    <CookieBanner client:load />

    <!-- Lenis smooth scroll -->
    <SmoothScroll client:only="react" />

    <!-- Three.js WebGL scene — fixed canvas behind all UI -->
    <MainScene client:only="react" />

    <!-- Main Content Slot -->
    <slot />

    <!-- Site Footer — single source of truth, rendered on every page -->
    <footer id="site-footer">
      <div class="footer-inner">

        <!-- Line 1: name wordmark — links to homepage -->
        <a href="https://mohamedgedan.de/" class="footer-brand" style="display: flex; align-items: center; gap: 8px;">
          <InteractiveLogo client:load width={24} height={24} />
          MOHAMED GEDAN
        </a>

        <!-- Line 2: copyright · tech stack · social links -->
        <div class="footer-row">
          <span class="footer-copy">
            &copy; <span id="footer-year"></span> Mohamed Gedan.
            <span data-de="Alle Rechte vorbehalten · Gemäß DSGVO / TTDSG.">All rights reserved · Compliant with GDPR / TTDSG.</span>
          </span>
          <span class="footer-sep" aria-hidden="true">·</span>
          <span class="footer-tech">
            <span data-de="Erstellt mit">Built with</span>
            <strong class="tech-astro">Astro</strong> + <strong class="tech-react">React</strong> + Scoped <strong class="tech-css">Vanilla CSS</strong>
          </span>
          <span class="footer-sep" aria-hidden="true">·</span>
          <div class="footer-social">
            <a href="https://www.linkedin.com/in/mohamed-sayed-eng/" target="_blank" rel="noopener noreferrer" class="footer-link social-linkedin">LINKEDIN</a>
            <span class="footer-dot" aria-hidden="true">·</span>
            <a href="https://github.com/MSHcomm" target="_blank" rel="noopener noreferrer" class="footer-link social-github">GITHUB</a>
          </div>
        </div>

        <!-- Line 3: legal links -->
        <div class="footer-legal">
          <a href="/impressum"   class="footer-link" data-de="Impressum">Legal Notice</a>
          <span class="footer-dot" aria-hidden="true">·</span>
          <a href="/datenschutz" class="footer-link" data-de="Datenschutz">Privacy Policy</a>
          <span class="footer-dot" aria-hidden="true">·</span>
          <a href="/disclaimer"  class="footer-link" data-de="Haftungsausschluss">Disclaimer</a>
        </div>

      </div>
    </footer>

    <style>
      .mobile-icons-container { align-items: center; }

      @media (max-width: 991px) {
        .nav-links { display: none !important; }
        .mobile-icons-container { display: flex !important; }
      }

      /* ── Site Footer ────────────────────────────────────────────────────── */
      #site-footer {
        position: relative;
        z-index: 10;
        border-top: 1px solid var(--card-border, rgba(255,255,255,0.08));
        background: var(--card-bg-lowest);
        padding: 20px 24px 18px;
      }

      .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-secondary);
        text-align: center;
      }

      /* Name wordmark — blue, hover brightens */
      .footer-brand {
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-decoration: none;
        color: #58A6FF;
        transition: color 0.18s, text-shadow 0.18s;
      }
      .footer-brand:hover {
        color: #a0cfff;
        text-shadow: 0 0 12px rgba(88, 166, 255, 0.45);
      }

      .footer-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
        gap: 6px;
      }

      /* Copyright — orange */
      .footer-copy {
        color: #E8883A;
      }

      /* Tech stack — brand colours per technology */
      .footer-tech { color: var(--text-secondary); }

      .tech-astro   { color: #FF5D01; font-weight: 600; transition: color 0.18s; } /* Astro orange */
      .tech-react   { color: #61DAFB; font-weight: 600; transition: color 0.18s; } /* React cyan   */
      .tech-css     { color: #A78BFA; font-weight: 600; transition: color 0.18s; } /* CSS purple   */

      .tech-astro:hover { color: #ff8a45; }
      .tech-react:hover { color: #a8eeff; }
      .tech-css:hover   { color: #c4b5fd; }

      .footer-social {
        display: flex;
        align-items: center;
        gap: 6px;
      }

      /* LinkedIn — LinkedIn blue; GitHub — white/gray */
      .social-linkedin {
        color: #0A66C2;
        text-decoration: none;
        transition: color 0.18s;
        font-weight: 600;
      }
      .social-linkedin:hover { color: #5ba8f5; }

      .social-github {
        color: #8B949E;
        text-decoration: none;
        transition: color 0.18s;
        font-weight: 600;
      }
      .social-github:hover { color: #e6edf3; }

      .footer-legal {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        justify-content: center;
        gap: 6px;
      }

      /* Legal links — muted, hover primary blue */
      .footer-link {
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.18s;
      }
      .footer-link:hover { color: #58A6FF; }

      .footer-sep,
      .footer-dot { opacity: 0.35; }

      @media (max-width: 767px) {
        .footer-row {
          flex-direction: column;
          gap: 12px;
        }
        .footer-sep { display: none; }
      }
    </style>

    <script>
      // ── Static i18n swap engine ──────────────────────────────────────────────
      // Elements with [data-de] switch textContent on language change.
      // EN values are captured once from the DOM on first load.
      (function () {
        function captureEn() {
          document.querySelectorAll('[data-de]').forEach(el => {
            if (!el.dataset.en) el.dataset.en = el.textContent;
          });
        }

        function applyLang(lang) {
          document.documentElement.setAttribute('lang', lang);
          document.querySelectorAll('[data-de]').forEach(el => {
            el.textContent = lang === 'de'
              ? el.dataset.de
              : (el.dataset.en || el.textContent);
          });
        }

        captureEn();
        let initLang = localStorage.getItem('lang');
        if (!initLang) {
          initLang = navigator.language.startsWith('de') ? 'de' : 'en';
        }
        if (initLang === 'de') applyLang('de');

        document.addEventListener('langchange', e => applyLang(e.detail));
      })();

      // ── Scroll Reveal ────────────────────────────────────────────────────────
      const observer = new IntersectionObserver(
        entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { root: null, rootMargin: '0px', threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // ── Scroll spy ───────────────────────────────────────────────────────────
      window.addEventListener('scroll', () => {
        const sections = ['hero', 'experience', 'skills', 'certifications', 'languages', 'education', 'reference'];
        let current = 'hero';
        sections.forEach(id => {
          const el = document.getElementById(id);
          if (el) { const r = el.getBoundingClientRect(); if (r.top <= 180 && r.bottom >= 180) current = id; }
        });
        document.querySelectorAll('.nav-item').forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === `#${current}`);
        });
      });

      // ── Mobile Menu ──────────────────────────────────────────────────────────
      const menuToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      if (menuToggle && mobileMenu) {
        menuToggle.addEventListener('click', () => {
          const hidden = mobileMenu.style.display === 'none';
          mobileMenu.style.display = hidden ? 'flex' : 'none';
          menuToggle.textContent = hidden ? 'close' : 'menu';
        });
        document.querySelectorAll('.mobile-nav-item').forEach(item => {
          item.addEventListener('click', () => {
            mobileMenu.style.display = 'none';
            menuToggle.textContent = 'menu';
          });
        });
      }

      // ── Footer year ──────────────────────────────────────────────────────────
      const fy = document.getElementById('footer-year');
      if (fy) fy.textContent = new Date().getFullYear();
    </script>
  </body>
</html>
